<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!--
      Le rôle ROLE_CALL_SCREENING suffit à filtrer les appels et à lire le numéro
      entrant. Aucune permission sensible : vie privée d'abord.
      INTERNET (permission normale, non dangereuse) sert uniquement à télécharger
      les presets communautaires publics ; aucune donnée d'appel n'est envoyée.
    -->
    <uses-permission android:name="android.permission.INTERNET" />

    <application
        android:name=".CallControllerApp"
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.CallController">

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:label="@string/app_name"
            android:theme="@style/Theme.CallController">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Service de filtrage appelé par le système avant la sonnerie. -->
        <service
            android:name=".screening.ServiceFiltrageAppels"
            android:exported="true"
            android:permission="android.permission.BIND_SCREENING_SERVICE">
            <intent-filter>
                <action android:name="android.telecom.CallScreeningService" />
            </intent-filter>
        </service>
    </application>
</manifest>
